        "jsCode": "// Use correct fields from previous node\nconst customerName = $('Node_Only_read_specific_keyWords').first().json.customerName\nconst customerEmail =$('Node_Only_read_specific_keyWords').first().json.customerEmail\nconst subject = $('Node_Only_read_specific_keyWords').first().json.subject\nconst bodyText = $('Node_Only_read_specific_keyWords').first().json.bodyText\n\n// Generate ticket ID (keep existing if present)\nconst ticketId = $('Node_Only_read_specific_keyWords').first().json.ticketId\n\n// Timestamp\nconst receivedAt = $('Node_Only_read_specific_keyWords').first().json.receivedAt\n\n// LLM outputs\nconst category = $input.first().json.text\nconst confidence = $json.confidence || 0;\nconst summary = $json.summary || \"\";\n\n// Final structured output\nreturn [\n  {\n    json: {\n      ticketId,\n      customerName,\n      customerEmail,\n      subject,\n      bodyText,\n      category,\n      confidence,\n      summary,\n      receivedAt\n    }\n  }\n];"
      },
