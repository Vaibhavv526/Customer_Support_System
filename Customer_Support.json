      "parameters": {
        "jsCode": "return items.map(item => {\n  const e = item.json;\n\n  // --- Extract fields safely ---\n  let from = \"\";\n  let subject = e.subject || \"\";\n  let body = e.textPlain || e.text || \"\";\n\n  // Handle sender formats\n  if (e.from?.value?.[0]) {\n    from = e.from.value[0].address || \"\";\n  } else if (typeof e.from === \"string\") {\n    from = e.from;\n  }\n\n  // --- Clean body ---\n  const cleanBody = body\n    .replace(/\\r\\n/g, \"\\n\")\n    .replace(/\\n{2,}/g, \"\\n\")\n    .trim();\n\n  // --- Keyword detection (customize if needed) ---\n  const keywords = [\"feedback\", \"review\", \"suggestion\", \"thanks\", \"appreciate\"];\n  \n  const isRelevant = keywords.some(k =>\n    (subject + \" \" + cleanBody).toLowerCase().includes(k)\n  );\n\n  return {\n    json: {\n      ticketId: \"TKT-\" + Date.now(),\n      customerEmail: from,\n      customerName: from.split(\"@\")[0] || \"\",\n      subject: subject,\n      bodyText: cleanBody,\n      receivedAt: e.date || new Date().toISOString(),\n      isRelevant: isRelevant   // 👈 IMPORTANT: don't block, just tag\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
