    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a customer support issue classifier.\nClassify the following issue into exactly ONE category:\n\n- BILLING     → charges, invoices, refunds, subscription, payment failure\n- PRODUCT     → features, bugs, how-to, setup, performance issues\n- ACCOUNT     → login, password reset, 2FA, profile, data access\n- PAYMENT     → transaction errors, card declined, bank disputes\n- ABUSE       → harassment, threats, policy violations, bullying\n- OTHER       → anything that doesn't fit above\n\nReturn JSON only:\n{\n  \"category\": \"BILLING|PRODUCT|ACCOUNT|PAYMENT|ABUSE|OTHER\",\n  \"confidence\": 0.0-1.0,\n  \"summary\": \"one sentence describing the issue\"\n}\n\nCustomer issue:\nSubject: {{ $('Code in JavaScript').item.json.subject }}\nBody: {{ $('Code in JavaScript').item.json.bodyText }}\nCustomer Name: {{ $('Code in JavaScript').item.json.customerName }}\nCustomer Email: {{ $('Code in JavaScript').item.json.customerEmail }}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1488,
        -256
      ],
      "id": "8b3fb5f7-df52-4707-845a-ae3a1d6d4453",
